<%- include('partials/header') %>

<div class="toolbar">
  <div>
    <h1 class="page-title">Productos</h1>
    <p class="page-sub" style="margin-bottom:0">Catálogo e inventario de la farmacia.</p>
  </div>
  <% if (user.rol === 'ADMIN') { %>
    <a href="/productos/nuevo" class="btn">+ Nuevo producto</a>
  <% } %>
</div>

<div class="panel">
  <table>
    <thead>
      <tr>
        <th>Código</th><th>Nombre</th><th>Laboratorio</th>
        <th>Precio (Bs)</th><th>Stock</th>
        <% if (user.rol === 'ADMIN') { %><th>Acciones</th><% } %>
      </tr>
    </thead>
    <tbody>
      <% productos.forEach(p => { %>
        <tr>
          <td><%= p.codigo %></td>
          <td><%= p.nombre %></td>
          <td><%= p.laboratorio || '—' %></td>
          <td><%= Number(p.precio).toFixed(2) %></td>
          <td>
            <span class="badge <%= p.stock < 5 ? 'badge-bajo' : 'badge-ok' %>"><%= p.stock %></span>
          </td>
          <% if (user.rol === 'ADMIN') { %>
            <td class="actions">
              <a href="/productos/editar/<%= p.id %>" class="btn btn-sm btn-ghost">Editar</a>
              <form action="/productos/eliminar/<%= p.id %>" method="POST" onsubmit="return confirm('¿Eliminar este producto?')">
                <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
              </form>
            </td>
          <% } %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<h1 class="page-title"><%= producto ? 'Editar producto' : 'Nuevo producto' %></h1>
<p class="page-sub">Completa los datos del producto.</p>

<div class="panel" style="max-width:520px">
  <form action="<%= producto ? '/productos/editar/' + producto.id : '/productos/nuevo' %>" method="POST">
    <div class="form-group">
      <label>Código</label>
      <input type="text" name="codigo" value="<%= producto ? producto.codigo : '' %>" required>
    </div>
    <div class="form-group">
      <label>Nombre</label>
      <input type="text" name="nombre" value="<%= producto ? producto.nombre : '' %>" required>
    </div>
    <div class="form-group">
      <label>Precio (Bs)</label>
      <input type="number" step="0.01" name="precio" value="<%= producto ? producto.precio : '' %>" required>
    </div>
    <div class="form-group">
      <label>Stock</label>
      <input type="number" name="stock" value="<%= producto ? producto.stock : '0' %>" required>
    </div>
    <div class="form-group">
      <label>Laboratorio</label>
      <input type="text" name="laboratorio" value="<%= producto ? (producto.laboratorio || '') : '' %>">
    </div>
    <div class="actions">
      <button type="submit" class="btn">Guardar</button>
      <a href="/productos" class="btn btn-ghost">Cancelar</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
